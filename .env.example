# AI provider:
#   claude-code  Claude Code agent — local use, reads lab files directly (default)
#   claude       Raw Anthropic API — for cloud/server deployment
#   kimi         Kimi API (OpenAI-compatible)
AI_PROVIDER=claude-code

# Anthropic Claude API key (used when AI_PROVIDER=claude)
CLAUDE_API_KEY=your-claude-api-key-here

# Kimi API key (used when AI_PROVIDER=kimi)
KIMI_API_KEY=your-kimi-api-key-here

# JWT secret — change this to a long random string before deploying!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string

HOST=127.0.0.1
PORT=8080
